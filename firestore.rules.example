rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // PEDIDOS - Permitir creación pública para formulario web
    // ==========================================
    match /pedidos/{pedidoId} {
      // Permitir crear pedidos desde la web (sin autenticación)
      // IMPORTANTE: Solo permite crear, no leer ni modificar sin auth
      allow create: if request.resource.data.canal == 'web'
                    && request.resource.data.creadoPor == 'sistema-web';

      // Para leer, actualizar o eliminar, requiere autenticación
      allow read, update, delete: if request.auth != null;

      // Subcolección items
      match /items/{itemId} {
        allow create: if get(/databases/$(database)/documents/pedidos/$(pedidoId)).data.canal == 'web';
        allow read, update, delete: if request.auth != null;
      }

      // Subcolección historial
      match /historial/{historialId} {
        allow create: if get(/databases/$(database)/documents/pedidos/$(pedidoId)).data.canal == 'web';
        allow read: if request.auth != null;
      }
    }

    // ==========================================
    // NOTIFICACIONES - Permitir crear para sistema web
    // ==========================================
    match /notificaciones/{notifId} {
      allow create: if request.resource.data.tipo == 'nuevo_pedido';
      allow read, update, delete: if request.auth != null;
    }

    // ==========================================
    // TURNOS - Solo lectura pública para obtener turno activo
    // ==========================================
    match /turnos/{turnoId} {
      allow read: if true; // Permitir leer turnos públicamente
      allow write: if request.auth != null;
    }

    // ==========================================
    // PRODUCTOS - Lectura pública para catálogo
    // ==========================================
    match /productos/{productoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==========================================
    // CATEGORÍAS - Lectura pública para catálogo
    // ==========================================
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==========================================
    // COLONIAS - Lectura pública para formulario
    // ==========================================
    match /colonias/{coloniaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==========================================
    // OTRAS COLECCIONES - Requieren autenticación
    // ==========================================
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }

    match /clientes/{clienteId} {
      allow read, write: if request.auth != null;
    }

    match /configuracion/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
